{
  "name": "polymarket-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Trading tool scaffold for Polymarket",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "tsx --test tests/unit/**/*.test.ts tests/unit/*.test.mjs",
    "lint": "eslint . --ext .ts",
    "migration:up": "tsx src/storage/migrate.ts up",
    "migration:down": "tsx src/storage/migrate.ts down"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "pg-mem": "^3.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
